# AI_API_KEY: Optional. Your AI service provider's API key.
# Leave empty for local models that don't require authentication (e.g. Ollama).
AI_API_KEY=""

# AI_BASE_URL: Optional. Override the default API base URL.
# Required for non-Google providers or local models.
# Examples:
#   DeepSeek:         https://api.deepseek.com
#   Google Gemini:    https://generativelanguage.googleapis.com/v1beta/openai
#   OpenAI:           https://api.openai.com/v1
#   Ollama local:     http://localhost:11434/v1
# AI_BASE_URL="http://localhost:11434/v1"

# AI_MODEL: Optional. The model to use for generation.
# AI_MODEL="deepseek-v4-flash"

# AI_MODELS: Optional. Comma-separated list of available models for frontend selection.
# If not set, only AI_MODEL will be available.
# AI_MODELS="deepseek-v4-flash,deepseek-v4-pro"

# PORT: The port for the backend server (default: 3000 for production, 3001 for dev).
# PORT=3000

# Provider configurations (auto-mapped to UI)
# Format: PROVIDER_{ID}_{FIELD}
# Fields: NAME, BASE_URL, API_KEY
# - API_KEY: default API key. Fill in to auto-populate on UI. Leave empty if not configured yet.
# Add a new provider by adding 3 lines below. No code changes needed.

PROVIDER_OPENAI_NAME="OpenAI"
PROVIDER_OPENAI_BASE_URL="https://api.openai.com/v1"
PROVIDER_OPENAI_API_KEY=""

PROVIDER_DEEPSEEK_NAME="DeepSeek"
PROVIDER_DEEPSEEK_BASE_URL="https://api.deepseek.com"
PROVIDER_DEEPSEEK_API_KEY=""

PROVIDER_NVIDIA_NAME="NVIDIA NIM"
PROVIDER_NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
PROVIDER_NVIDIA_API_KEY=""

PROVIDER_GEMINI_NAME="Google Gemini"
PROVIDER_GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
PROVIDER_GEMINI_API_KEY=""

PROVIDER_SILICONFLOW_NAME="SiliconFlow"
PROVIDER_SILICONFLOW_BASE_URL="https://api.siliconflow.cn/v1"
PROVIDER_SILICONFLOW_API_KEY=""

PROVIDER_OLLAMA_NAME="Ollama (本地)"
PROVIDER_OLLAMA_BASE_URL="http://localhost:11434/v1"
PROVIDER_OLLAMA_API_KEY=""

PROVIDER_OPENROUTER_NAME="OpenRouter"
PROVIDER_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
PROVIDER_OPENROUTER_API_KEY=""

PROVIDER_CUSTOM_NAME="自定义"
PROVIDER_CUSTOM_BASE_URL=""
PROVIDER_CUSTOM_API_KEY=""
